{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash ./scripts/hook-pass.sh session-start",
        "timeout": 10
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash ./scripts/hook-pass.sh pre-tool-use",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "bash ./scripts/hook-pass.sh post-tool-use",
        "timeout": 10
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "command": "bash ./scripts/subagent-log.sh",
        "timeout": 10
      }
    ],
    "SubagentStop": [
      {
        "type": "command",
        "command": "bash ./scripts/subagent-log.sh",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash ./scripts/hook-pass.sh stop",
        "timeout": 10
      }
    ]
  }
}
