{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "./scripts/session-init.sh",
        "description": "Initialize session and load project context"
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "./scripts/security-check.sh",
        "description": "Block dangerous operations",
        "timeout": 10
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "command": "npx prettier --write .",
        "description": "Format files after edits",
        "cwd": ".",
        "windows": "powershell -File scripts\\format.ps1",
        "timeout": 30
      },
      {
        "type": "command",
        "command": "./scripts/audit-log.sh",
        "description": "Log all tool usage for audit",
        "timeout": 5
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "./scripts/session-cleanup.sh",
        "description": "Generate session report and cleanup"
      }
    ]
  }
}
