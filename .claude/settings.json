{
  "hooks": {
    "SubagentStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/subagent-log.sh",
            "timeout": 10,
            "statusMessage": "Logging subagent start"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./scripts/subagent-log.sh",
            "timeout": 10,
            "statusMessage": "Logging subagent stop"
          }
        ]
      }
    ]
  }
}
